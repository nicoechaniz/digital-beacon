# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/

# venv from sibling projects (don't shadow)
.env

# OSC / runtime
*.log
logs/
.cache/

# Recorded audio
*.wav
*.aif
recordings/

# User presets (local-only, like beacon-spatial)
configs/user_*.json
!configs/*.default.json

# Build artifacts (regenerated by build_voice_compare_v3.py)
tools/voice_compare.html
tools/voice_compare_data.json

# User presets named without "user_" prefix (e.g. Amora.json,
# sesion 24 jun 2026 - shaper pre-save.json). The .default.json files are
# explicitly checked in; all other .json files in configs/ are user saves.
# Pattern: any .json in configs/ that is NOT already tracked AND is not
# *.default.json will be ignored. Since gitignore can't express "untracked
# only", we use a broad pattern and rely on `git add -f configs/X.default.json`
# to commit explicit defaults.
configs/*.json
!configs/*.default.json
